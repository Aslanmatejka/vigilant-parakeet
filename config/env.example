# Supabase Configuration (frontend — VITE_ prefix required for Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Configuration (backend — service role for server-side operations)
# Get from: Supabase Dashboard > Settings > API > service_role key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Environment
NODE_ENV=development

# Port (optional)
PORT=3001

# AI Configuration (backend only — NOT exposed to frontend)
OPENAI_API_KEY=your-openai-api-key-here

# Site URL — used by Supabase auth redirects (password reset, email confirm).
# Falls back to window.location.origin when unset.
VITE_SITE_URL=http://localhost:3001

# CORS origins for FastAPI backend (comma-separated)
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Mapbox Configuration
VITE_MAPBOX_TOKEN=your-mapbox-public-token-here
MAPBOX_TOKEN=your-mapbox-public-token-here

# Email Configuration (Resend SMTP for Supabase auth emails)
# Sign up at https://resend.com, get API key, verify your domain
RESEND_API_KEY=re_your-resend-api-key-here
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_your-resend-api-key-here

# Twilio Configuration (for SMS notifications)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_PHONE_NUMBER=+1234567890

# Storage Configuration
STORAGE_BUCKET=your-storage-bucket-name 